{
  "name": "warkop-order-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && npx firebase-tools deploy",
    "deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "deploy:firestore": "npx firebase-tools deploy --only firestore:rules",
    "migrate:firestore": "node -e \"const path=require('node:path'); const { pathToFileURL }=require('node:url'); const base=(process.env.INIT_CWD||process.cwd()).replace(/^\\\\\\\\\\?\\\\/,''); import(pathToFileURL(path.join(base,'scripts','migrate-firestore.mjs')).href)\" --"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.576.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^13.7.0",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
